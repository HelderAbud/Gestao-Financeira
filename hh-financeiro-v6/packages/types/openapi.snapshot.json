  "components": {
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "password": { "type": "string" }
        },
        "required": ["email", "password"]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "password": { "type": "string" }
        },
        "required": ["email", "password"]
      },
      "TokenResponse": {
        "type": "object",
        "properties": { "accessToken": { "type": "string" } }
      },
      "UserMeResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "email": { "type": "string" }
        }
      },
      "MonthlySummaryResponse": {
        "type": "object",
        "properties": {
          "year": { "type": "integer" },
          "month": { "type": "integer" },
          "totalIncome": { "type": "number" },
          "totalExpenseOutflows": { "type": "number" },
          "totalInvestments": { "type": "number" },
          "balance": { "type": "number" }
        }
      },
      "MonthlyInsightResponse": {
        "type": "object",
        "properties": {
          "text": { "type": "string" },
          "mode": { "type": "string", "enum": ["OPENAI", "RULE_BASED"] }
        }
      },
      "ExpenseCreateRequest": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "amount": { "type": "number" },
          "category": { "type": "string" },
          "expenseType": { "type": "string", "enum": ["FIXED", "VARIABLE"] },
          "month": { "type": "integer" },
          "year": { "type": "integer" },
          "entryDate": { "type": "string", "format": "date" },
          "notes": { "type": "string" },
          "subscriptionId": { "type": "integer", "format": "int64" }
        },
        "required": ["description", "amount", "category", "expenseType", "month", "year", "entryDate"]
      },
      "ExpenseResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "description": { "type": "string" },
          "amount": { "type": "number" },
          "category": { "type": "string" },
          "expenseType": { "type": "string", "enum": ["FIXED", "VARIABLE"] },
          "month": { "type": "integer" },
          "year": { "type": "integer" },
          "entryDate": { "type": "string", "format": "date" },
          "notes": { "type": "string" },
          "subscriptionId": { "type": "integer", "format": "int64" }
        }
      },
      "IncomeCreateRequest": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "amount": { "type": "number" },
          "category": { "type": "string" },
          "month": { "type": "integer" },
          "year": { "type": "integer" },
          "entryDate": { "type": "string", "format": "date" },
          "notes": { "type": "string" }
        },
        "required": ["description", "amount", "category", "month", "year", "entryDate"]
      },
      "IncomeResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "description": { "type": "string" },
          "amount": { "type": "number" },
          "category": { "type": "string" },
          "month": { "type": "integer" },
          "year": { "type": "integer" },
          "entryDate": { "type": "string", "format": "date" },
          "notes": { "type": "string" }
        }
      },
      "GoalCreateRequest": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "targetAmount": { "type": "number" }
        },
        "required": ["description", "targetAmount"]
      },
      "GoalResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "description": { "type": "string" },
          "targetAmount": { "type": "number" },
          "currentAmount": { "type": "number" }
        }
      },
      "GoalDepositRequest": {
        "type": "object",
        "properties": { "amount": { "type": "number" } },
        "required": ["amount"]
      },
      "GoalDepositResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "amount": { "type": "number" },
          "recordedAt": { "type": "string", "format": "date-time" }
        }
      },
      "SubscriptionCreateRequest": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "amount": { "type": "number" },
          "category": { "type": "string" }
        },
        "required": ["description", "amount", "category"]
      },
      "SubscriptionResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "description": { "type": "string" },
          "amount": { "type": "number" },
          "category": { "type": "string" }
        }
      },
      "BudgetUpsertRequest": {
        "type": "object",
        "properties": {
          "year": { "type": "integer" },
          "month": { "type": "integer" },
          "category": { "type": "string" },
          "plannedAmount": { "type": "number" }
        },
        "required": ["year", "month", "category", "plannedAmount"]
      },
      "BudgetResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "year": { "type": "integer" },
          "month": { "type": "integer" },
          "category": { "type": "string" },
          "plannedAmount": { "type": "number" }
        }
      }
    }
  }
}
